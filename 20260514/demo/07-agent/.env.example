# Copy to .env and fill in real values.
# Never commit .env to git.

# --- Telegram --------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to talk to the bot.
# Leave empty to allow anyone (NOT recommended for demos).
ALLOWED_CHAT_IDS=

# Default chat to send scheduler / monitor pushes to.
TELEGRAM_DEFAULT_CHAT_ID=

# --- KIS Open API ----------------------------------------------------------
# Issued at https://apiportal.koreainvestment.com/about-howto
# Use 모의투자 (vts) credentials for the demo unless you really want real
# orders to be possible.

# vts (모의투자) | real (실전투자)
KIS_ENV=vts

# App key + secret from KIS Open API portal
KIS_APP_KEY=
KIS_APP_SECRET=

# --- Anthropic (optional) --------------------------------------------------
# Only needed if running `claude` from cron/launchd contexts where the
# macOS keychain login session is not available. Leave empty for interactive use.
ANTHROPIC_API_KEY=

# --- Watches (optional) ----------------------------------------------------
# Where the bot persists active price watches. Defaults to data/watches.json.
# WATCHES_FILE=
