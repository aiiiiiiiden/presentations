{
  "mcpServers": {
    "kis-code-assistant-mcp": {
      "command": "uv",
      "args": [
        "--directory",
        "./vendor/open-trading-api/MCP/KIS Code Assistant MCP",
        "run",
        "server.py",
        "--stdio"
      ]
    },
    "kis-data": {
      "command": "npx",
      "args": ["tsx", "src/kis-mcp/server.ts"]
    }
  }
}
